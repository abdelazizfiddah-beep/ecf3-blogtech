{% extends 'base.html.twig' %}

{% block title %}Catégorie {{ category.name }} - BlogTech{% endblock %}

{% block body %}
    <h1>Catégorie : {{ category.name }}</h1>

    {% for article in articles %}
        {% include 'article/_article_card.html.twig' with { article: article } %}
    {% else %}
        <p>Aucun article publié dans cette catégorie.</p>
    {% endfor %}
{% endblock %}
