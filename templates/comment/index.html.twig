{% extends 'base.html.twig' %}

{% block title %}Comment index
{% endblock %}

{% block body %}
	<h1>Comment index</h1>

	<table class="table">
		<thead>
			<tr>
				<th>Id</th>
				<th>Content</th>
				<th>CreatedAt</th>
				<th>Approved</th>
				<th>actions</th>
			</tr>
		</thead>
		<tbody>
			{% for comment in comments %}
				<tr>
					<td>{{ comment.id }}</td>
					<td>{{ comment.content }}</td>
					<td>{{ comment.createdAt ? comment.createdAt|date('Y-m-d H:i:s') : '' }}</td>
					<td>{{ comment.approved ? 'Yes' : 'No' }}</td>
					<td>
						<button type="button" data-controller="comment-toggle" data-comment-toggle-url-value="{{ path('app_comment_toggle_status', {'id': comment.id}) }}" data-comment-toggle-approved-value="{{ comment.approved ? '1' : '0' }}">
							Toggle
						</button>

						<a href="{{ path('app_comment_show', {'id': comment.id}) }}">show</a>
						<a href="{{ path('app_comment_edit', {'id': comment.id}) }}">edit</a>
					</td>
				</tr>
			{% else %}
				<tr>
					<td colspan="5">no records found</td>
				</tr>
			{% endfor %}
		</tbody>
	</table>

	<a href="{{ path('app_comment_new') }}">Create new</a>
{% endblock %}
